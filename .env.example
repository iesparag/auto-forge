# Required - set a random string (32+ chars) used to encrypt stored secrets
SECRET_KEY=change_this_to_a_random_32_char_string

# Server
PORT=3000

# MongoDB connection string.
# Local:  mongodb://localhost:27017/autoforge
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/autoforge
MONGODB_URI=mongodb+srv://iesparagjain:iesparagjain@cluster0.boltvzz.mongodb.net/autoforge

# All other secrets (Anthropic key, GitHub token, Gmail creds, etc.)
# are saved via the Settings UI and stored encrypted in MongoDB.
